---
import SectionHeading from "@/components/SectionHeading.astro";
import ArrowUpRight from "@/icons/ArrowUpRight.astro";

const PROJECTS = [
    {
        link: "#",
        title: "RPGConstrulivianas",
        attachment: "Landing page · 2024",
        description: "Portal web oficial para RPG Construlivianas S.A.S., empresa de construcción colombiana, muestra sus servicios, proyectos y experiencia.",
        tags: ["HTML", "CSS", "JavaScript"]
    },
    {
        link: "#",
        title: "RPGConstrulivianas",
        attachment: "Landing page · 2024",
        description: "Portal web oficial para RPG Construlivianas S.A.S., empresa de construcción colombiana, muestra sus servicios, proyectos y experiencia.",
        tags: ["HTML", "CSS", "JavaScript"]
    },
    {
        link: "#",
        title: "RPGConstrulivianas",
        attachment: "Landing page · 2024",
        description: "Portal web oficial para RPG Construlivianas S.A.S., empresa de construcción colombiana, muestra sus servicios, proyectos y experiencia.",
        tags: ["HTML", "CSS", "JavaScript"]
    }
]
---

<section id="projects" class="scroll-mt-24 pt-20">
    <SectionHeading index="02" title="Proyectos" />

    <div class="grid gap-3">
        {
            PROJECTS.map(project => (
                <a href={project.link} class="group rounded-lg border border-border bg-card/60 p-5 transition-all hover:border-primary/40 hover:bg-card">
                    <div class="flex flex-wrap items-start justify-between md:gap-4">
                        <div class="flex items-center gap-3">
                            <h3 class="font-heading text-lg font-semibold text-foreground transition-colors group-hover:text-primary">
                                {project.title}
                            </h3>
                            <ArrowUpRight class="size-4 text-muted-foreground transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-primary"/>
                        </div>
                        <span class="shrink-0 font-mono text-xs text-muted-foreground">
                            {project.attachment}
                        </span>
                    </div>
        
                    <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                        {project.description}
                    </p>
        
                    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
                        <div class="flex flex-wrap gap-1.5">
                            {
                                project.tags.map(tag => (
                                    <span class="rounded border border-border bg-secondary/40 px-2 py-0.5 font-mono text-[11px] text-foreground/80">
                                        {tag}
                                    </span>
                                ))
                            }
                        </div>
                    </div>
                </a>
            ))
        }
    </div>
</section>