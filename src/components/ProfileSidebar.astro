---
import ArrowUpRight from "@/icons/ArrowUpRight.astro";
import Github from "@/icons/Github.astro";
import Linkedin from "@/icons/Linkedin.astro";
import MapPin from "@/icons/MapPin.astro";
---

<header class="py-12 lg:sticky lg:top-0 lg:flex lg:h-screen lg:max-h-screen lg:w-[44%] lg:flex-col lg:justify-between lg:py-24 lg:pr-12">
    <div>
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-border bg-card/60 px-3 py-1.5 font-mono text-xs text-muted-foreground w-fit">
            <span class="relative flex size-2">
                <span class="absolute inline-flex size-full animate-ping rounded-full bg-primary opacity-60"></span>
                <span class="relative inline-flex size-2 rounded-full bg-primary"></span>
            </span>
            Disponible para trabajar
        </div>
    
        <h1 class="font-heading text-5xl font-bold leading-none tracking-tight text-balance sm:text-6xl">
            Mateo López
        </h1>
    
        <p class="mt-4 font-mono text-sm uppercase tracking-[0.18rem] text-primary">
            Desarrollador fullstack · Ingeniero DevSecOps
        </p>
    
        <p class="mt-5 max-w-sm text-base leading-relaxed text-muted-foreground text-pretty">
            Construyendo software que automatiza, escala y genera valor.
        </p>
    
        <p class="mt-5 flex items-center gap-2 font-mono text-xs text-muted-foreground">
            <MapPin class="size-3.5" aria-hidden="true" />
            Remoto · Medellín, Colombia
        </p>
    
        <nav class="mt-12 hidden lg:block">
            <ul class="space-y-1">
                <li>
                    <a href="#experience" class="group flex items-center gap-4 py-2 font-mono text-xs uppercase tracking-[0.15em]">
                        <span class="h-px transition-all duration-300 w-7 bg-border group-hover:w-12 group-hover:bg-muted-foreground"></span>
                        <span class="transition-colors text-muted-foreground group-hover:text-foreground">
                            <span class="mr-2 opacity-50">01</span>
                            Experiencia
                        </span>
                    </a>
                </li>
                <li>
                    <a href="#projects" class="group flex items-center gap-4 py-2 font-mono text-xs uppercase tracking-[0.15em]">
                        <span class="h-px transition-all duration-300 w-7 bg-border group-hover:w-12 group-hover:bg-muted-foreground"></span>
                        <span class="transition-colors text-muted-foreground group-hover:text-foreground">
                            <span class="mr-2 opacity-50">02</span>
                            proyectos
                        </span>
                    </a>
                </li>
                <li>
                    <a href="#about" class="group flex items-center gap-4 py-2 font-mono text-xs uppercase tracking-[0.15em]">
                        <span class="h-px transition-all duration-300 w-7 bg-border group-hover:w-12 group-hover:bg-muted-foreground"></span>
                        <span class="transition-colors text-muted-foreground group-hover:text-foreground">
                            <span class="mr-2 opacity-50">03</span>
                            Acerca de mi
                        </span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>

    <footer class="mt-12 flex items-center gap-4 lg:mt-0">
        <a href="https://github.com/Mat0wa3" target="_blank" rel="noreferrer" aria-label="GitHub profile" class="text-muted-foreground transition-colors hover:text-primary">
            <Github class="size-5"/>
        </a>
        <a href="https://linkedin.com/in/mateo-lopez-dev" target="_blank" rel="noreferrer" aria-label="LinkedIn profile" class="text-muted-foreground transition-colors hover:text-primary">
            <Linkedin class="size-5"/>
        </a>
        <a href="mailto:mmateo1804@gmail.com" class="ml-2 inline-flex items-center gap-1.5 font-mono text-xs text-muted-foreground transition-colors hover:text-primary">
            mmateo1804@gmail.com
            <ArrowUpRight class="size-3.5" aria-hidden="true" />
        </a>
    </footer>
</header>
<script type="module">
    (function(){
        const nav = document.querySelector('nav');
        if (!nav) return;
        const links = Array.from(nav.querySelectorAll('a[href^="#"]'));
        const firstSpanSel = 'span.h-px';
        const secondSpanSel = 'span.transition-colors';

        function clearActive(){
            links.forEach(a=>{
                const first = a.querySelector(firstSpanSel);
                const second = a.querySelector(secondSpanSel);
                if (first){
                    first.classList.remove('w-14','bg-primary');
                    if (!first.classList.contains('w-7')) first.classList.add('w-7');
                    if (!first.classList.contains('bg-border')) first.classList.add('bg-border');
                }
                if (second){
                    second.classList.remove('text-primary');
                }
            });
        }

        function setActive(hash){
            if (!hash) return;
            clearActive();
            const a = links.find(l=>l.getAttribute('href')===hash);
            if (!a) return;
            const first = a.querySelector(firstSpanSel);
            const second = a.querySelector(secondSpanSel);
            if (first){
                first.classList.remove('w-7','bg-border');
                first.classList.add('w-14','bg-primary');
            }
            if (second){
                second.classList.add('text-primary');
            }
        }

        links.forEach(a=>{
            a.addEventListener('click', ()=>{
                // apply immediately on click
                setActive(a.getAttribute('href'));
            });
        });

        // Observe sections entering the viewport
        const sections = links.map(a=>document.querySelector(a.getAttribute('href'))).filter(Boolean);
        if (sections.length){
            const obs = new IntersectionObserver(entries=>{
                entries.forEach(entry=>{
                    if (entry.isIntersecting) setActive('#'+entry.target.id);
                });
            },{root:null,rootMargin:'0px',threshold:0.6});
            sections.forEach(s=>obs.observe(s));
        } else {
            // fallback to hash on load
            setActive(location.hash || links[0]?.getAttribute('href'));
        }
    })();
</script>