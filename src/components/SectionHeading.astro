---
interface Props {
    index: string,
    title: string
}

const { index, title } = Astro.props
---
<div class="mb-8 flex items-center gap-4">
    <span class="font-mono text-xs text-primary">{index}</span>
    <h2 class="font-heading text-sm font-semibold uppercase tracking-[0.18em] text-foreground">
        {title}
    </h2>
    <span class="h-px flex-1 bg-border"></span>
</div>